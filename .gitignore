# RAPID worktree working directories
.rapid-worktrees/

# RAPID per-worktree stub directories (ephemeral, generated from contracts)
.rapid-stubs/

# Worktree registry lock files
.planning/worktrees/*.lock

# RAPID remediation artifacts (ephemeral audit-to-set handoff)
.planning/pending-sets/

# Environment (generated by setup.sh, contains local paths)
.env

# RAPID install metadata (generated by setup.sh, contains local install timestamp)
.rapid-install-meta.json

# Dependencies
node_modules/
# Build outputs
dist/
*.tsbuildinfo

# Python bytecode
__pycache__/
*.pyc

# Note: agents/ is NOT gitignored. Generated files are committed so the plugin
# works immediately after clone without running setup.sh first.
# Source of truth is src/modules/. Regenerate with: node src/bin/rapid-tools.cjs build-agents


# planning files
v6.md
