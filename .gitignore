# RAPID worktree working directories
.rapid-worktrees/

# Worktree registry lock files
.planning/worktrees/*.lock

# Environment (generated by setup.sh, contains local paths)
.env

# Dependencies
node_modules/

# Build outputs
dist/
*.tsbuildinfo

# Python bytecode
__pycache__/
*.pyc

# Note: agents/ is NOT gitignored. Generated files are committed so the plugin
# works immediately after clone without running setup.sh first.
# Source of truth is src/modules/. Regenerate with: node src/bin/rapid-tools.cjs build-agents
