{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rapid://schemas/ui-contract",
  "title": "UI Contract Schema",
  "description": "Validates the structure of UI-CONTRACT.json files used by RAPID sets to declare UI design contracts.",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "guidelines": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fontFamilies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tone": {
          "type": "string"
        },
        "visualIdentity": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "grid": {
          "type": "object",
          "properties": {
            "columns": { "type": "number" },
            "gutter": { "type": "string" }
          }
        },
        "breakpoints": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "containerWidths": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "responsive": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "interactions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stateTransitions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "animations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "loadingPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "errorStates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "accessibility": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["page", "layout", "widget"]
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        }
      },
      "additionalProperties": false
    }
  }
}
